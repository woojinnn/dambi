{
  "id": "borrow-fraction-of-collateral-cap",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "borrow"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "post-borrow-hf",
      "method": "lending.health_factor",
      "params": {
        "action": "$.action",
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "venue": "$.action.venue"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "postActionHf",
          "type": "Decimal",
          "from": "$.result.postActionHf",
          "required": false
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "postActionHf": "decimal"
    }
  }
}
