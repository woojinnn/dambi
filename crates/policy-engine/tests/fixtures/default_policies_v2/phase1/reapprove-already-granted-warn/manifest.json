{
  "id": "reapprove-already-granted-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_approve" } } },
  "policy_rpc": [
    {
      "id": "already-granted",
      "method": "approval.already_granted",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "token": "$.action.token",
        "spender": "$.action.spender"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "alreadyGranted",
          "type": "Bool",
          "from": "$.result.alreadyGranted"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "alreadyGranted": "Bool" } }
}
