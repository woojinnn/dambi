{
  "id": "holding-pct-outflow-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_transfer" } } },
  "policy_rpc": [
    {
      "id": "holding-pct",
      "method": "token.outflow_pct_of_holding",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "token": "$.action.token",
        "amount": "$.action.amount"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "pctOfHolding",
          "type": "Decimal",
          "from": "$.result.pct"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "pctOfHolding": "decimal" } }
}
