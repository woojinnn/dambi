{
  "id": "increase-allowance-cap-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_approve" } } },
  "policy_rpc": [
    {
      "id": "resulting-allowance",
      "method": "approval.resulting_allowance_state",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "token": "$.action.token",
        "spender": "$.action.spender",
        "added_amount": "$.action.amount"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "resultingAllowanceOverBalance",
          "type": "Decimal",
          "from": "$.result.overBalance"
        },
        {
          "kind": "context",
          "field": "resultingAllowanceUnlimited",
          "type": "Bool",
          "from": "$.result.isUnlimited"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "resultingAllowanceOverBalance": "decimal",
      "resultingAllowanceUnlimited": "Bool"
    }
  }
}
