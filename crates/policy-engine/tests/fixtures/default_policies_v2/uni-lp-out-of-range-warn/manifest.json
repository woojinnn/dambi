{
  "id": "uni-lp-out-of-range-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "add_liquidity" } } },
  "policy_rpc": [
    {
      "id": "range-out-of-position",
      "method": "lp.range_out_of_position",
      "params": {
        "chain_id": "$.root.chain_id",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "lpOutOfRange",
          "type": "Bool",
          "from": "$.result.outOfRange"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "lpOutOfRange": "Bool" } }
}
