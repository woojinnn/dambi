{
  "id": "nft-bid-weth-unlimited-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_approve" } } },
  "policy_rpc": [
    {
      "id": "weth-approve-shape",
      "method": "approval.unlimited_over_balance",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "token": "$.action.token",
        "spender": "$.action.spender",
        "amount": "$.action.amount"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "bidApprovalIsUnlimited",
          "type": "Bool",
          "from": "$.result.isUnlimited"
        },
        {
          "kind": "context",
          "field": "bidApprovalOverBalance",
          "type": "Decimal",
          "from": "$.result.amountOverBalance"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "bidApprovalIsUnlimited": "Bool",
      "bidApprovalOverBalance": "decimal"
    }
  }
}
