{
  "id": "behav-overtrading-daily-count-warn",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "swap"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "swap-count-24h",
      "method": "order.swap_count_24h",
      "params": {
        "owner": "$.root.from"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "swapCount24h",
          "type": "Long",
          "from": "$.result.count"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "swapCount24h": "Long"
    }
  }
}
