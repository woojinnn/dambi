{
  "id": "transfer-recipient-lookalike-poisoning-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_transfer" } } },
  "policy_rpc": [
    {
      "id": "recipient-lookalike-history",
      "method": "order.recipient_lookalike_history",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "recipient": "$.action.recipient"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "recipientLookalike",
          "type": "Bool",
          "from": "$.result.lookalike"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "recipientLookalike": "Bool" } }
}
