{
  "id": "swap-native-gas-starvation-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "swap" } } },
  "policy_rpc": [
    {
      "id": "native-reserve-after",
      "method": "valuation.native_reserve_after",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "gas_estimate": "$.action.gasEstimate",
        "spend_asset": "$.action.tokenIn",
        "spend_amount": "$.action.direction.amountIn"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "nativeReserveBelowFloor",
          "type": "Bool",
          "from": "$.result.reserveBelowFloor"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "nativeReserveBelowFloor": "Bool" } }
}
