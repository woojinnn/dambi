{
  "id": "approve-spender-unknown-contract-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_approve" } } },
  "policy_rpc": [
    {
      "id": "spender-reputation",
      "method": "external.spender_reputation",
      "params": {
        "chain_id": "$.root.chain_id",
        "address": "$.action.spender"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "spenderUnknownContract",
          "type": "Bool",
          "from": "$.result.unknownContract"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "spenderUnknownContract": "Bool" } }
}
