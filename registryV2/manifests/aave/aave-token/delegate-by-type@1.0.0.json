{
  "type": "adapter_action",
  "id": "aave/aave-token/delegate-by-type@1.0.0",
  "publisher": "aave.eth",
  "note": "AAVE governance delegateByType(address,uint8) — delegates ONE governance power type (0=voting, 1=proposition). Maps to Airdrop::Delegate with power_type value-mapped from delegationType. AaveTokenV3 0x7fc66500c84a76ad7e9c93437bfc5ac33e2ddae9; selector keccak-verified.",
  "schema_version": "3",
  "match": {
    "selector": "0xdc937e1c",
    "chain_to_addresses": {
      "1": ["0x7fc66500c84a76ad7e9c93437bfc5ac33e2ddae9"]
    }
  },
  "abi_fragment": {
    "function_name": "delegateByType",
    "abi": {
      "name": "delegateByType",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "delegatee", "type": "address" },
        { "name": "delegationType", "type": "uint8" }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "airdrop",
      "airdrop": {
        "action": "delegate",
        "delegate": {
          "token": { "key": { "standard": "erc20", "chain": "$chain", "address": "$to" } },
          "delegatee": "$args.delegatee",
          "power_type": {
            "$match": "$args.delegationType",
            "$cases": { "0": "voting", "1": "proposition" }
          }
        }
      }
    },
    "live_inputs": {
      "current_delegate": { "source": { "kind": "derived_from", "inputs": [], "calc_id": "aave_token_current_delegate" }, "ttl_s": 60 },
      "voting_power": { "source": { "kind": "derived_from", "inputs": [], "calc_id": "aave_token_voting_power" }, "ttl_s": 60 }
    }
  },
  "requires": { "imperative": [], "adapter_capabilities": ["token_metadata"], "host_capabilities": [], "extension": ">=0.1.0" }
}
