{
  "type": "adapter_action",
  "id": "aave/v3/l2SupplyPacked@1.0.0",
  "publisher": "aave.eth",
  "schema_version": "3",
  "note": "Aave V3 Base L2Pool.supply(bytes32) packs reserve index, amount, referral code, and onBehalfOf into bytes32. Preserve as Unknown until the V3 declarative route can bit-slice the packed args and resolve reserve index to asset address.",
  "match": {
    "selector": "0xf7a73840",
    "chain_to_addresses": {
      "8453": ["0xa238dd80c259a72e81d7e4664a9801593f98d1c5"]
    }
  },
  "abi_fragment": {
    "function_name": "supply",
    "abi": {
      "name": "supply",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "args", "type": "bytes32" }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "unknown",
      "unknown": {
        "target": "$to",
        "chain": "$chain",
        "calldata": "$calldata",
        "value": "$tx.value"
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
