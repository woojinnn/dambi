{
  "type": "adapter_action",
  "id": "aave/v3/swapBorrowRateMode@1.0.0",
  "publisher": "aave.eth",
  "schema_version": "3",
  "note": "Aave V3 Pool.swapBorrowRateMode(asset, interestRateMode). Per the Aave V3 IPool NatSpec the interestRateMode arg is 'The current interest rate mode of the position being swapped: 1 for Stable, 2 for Variable' — i.e. the mode being swapped FROM. BorrowLogic.executeSwapBorrowRateMode burns the named-mode debt and mints the OTHER mode, so SwapRateModeAction.new_mode (the mode AFTER the swap) is the COMPLEMENT of the arg: arg 1 (STABLE) -> new_mode variable; arg 2 (VARIABLE) -> new_mode stable.",
  "match": {
    "selector": "0x94ba89a2",
    "chain_to_addresses": {
      "1":     ["0x87870bca3f3fd6335c3f4ce8392d69350b4fa4e2"],
      "10":    ["0x794a61358d6845594f94dc1db02a252b5b4814ad"],
      "8453":  ["0xa238dd80c259a72e81d7e4664a9801593f98d1c5"],
      "42161": ["0x794a61358d6845594f94dc1db02a252b5b4814ad"]
    }
  },
  "abi_fragment": {
    "function_name": "swapBorrowRateMode",
    "abi": {
      "name": "swapBorrowRateMode",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "asset",            "type": "address" },
        { "name": "interestRateMode", "type": "uint256" }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "swap_rate_mode",
        "swap_rate_mode": {
          "venue": {
            "name":      "aave_v3",
            "chain":     "$chain",
            "pool":      "$to",
            "market_id": null
          },
          "asset":    { "key": { "standard": "erc20", "chain": "$chain", "address": "$args.asset" } },
          "new_mode": { "$match": "$args.interestRateMode", "$cases": { "1": "variable", "2": "stable" } }
        }
      }
    },
    "live_inputs": {
      "current_debts": {
        "source": {
          "kind":       "onchain_view",
          "chain":      "$chain",
          "contract":   "$to",
          "function":   "getUserReserveData(address,address)",
          "decoder_id": "aave_v3_user_reserve_debts"
        },
        "ttl_s": 12
      },
      "rates": {
        "source": {
          "kind":       "onchain_view",
          "chain":      "$chain",
          "contract":   "$to",
          "function":   "getReserveData(address)",
          "decoder_id": "aave_v3_reserve_rates"
        },
        "ttl_s": 30
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
