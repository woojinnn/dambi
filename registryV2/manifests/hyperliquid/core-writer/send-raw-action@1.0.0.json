{
  "type": "adapter_action",
  "id": "hyperliquid/core-writer/sendRawAction@1.0.0",
  "publisher": "hyperliquid",
  "schema_version": "3",
  "match": {
    "selector": "0x17938e13",
    "chain_to_addresses": {
      "999": ["0x3333333333333333333333333333333333333333"],
      "998": ["0x3333333333333333333333333333333333333333"]
    }
  },
  "abi_fragment": {
    "function_name": "sendRawAction",
    "abi": {
      "name": "sendRawAction",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [{ "name": "data", "type": "bytes" }],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "tagged_dispatch",
    "bytes_source": "$args.data",
    "version_byte": "0x01",
    "tag_offset": 1,
    "tag_size": 3,
    "_note": "CoreWriter sendRawAction(bytes): data[0]=0x01 version, data[1:4]=action_id (uint24 BE), data[4:]=abi.encode(action args). action 1 maps to a structured hyperliquid_core::hl_core_limit_order raw body (asset id, raw limitPx/sz, isBuy/side, reduceOnly, encodedTif, cloid) without pretending to know human symbol/price/size units. actions 10/11 (cancel by oid/cloid) map to structured Perp(CancelOrder) bodies. Other actions + default map to hyperliquid_core::hl_unknown carrying a descriptive action_type (e.g. 'vaultTransfer') so a policy can gate the specific CoreWriter op by name. Fully human-scaled amounts remain deferred: HL uint64 fixed-point values need per-asset szDecimals/weiDecimals scaling from an HL meta snapshot; mislabeling a raw integer as a human amount would be worse than a raw structured body.",
    "per_action_body": {
      "1": {
        "name": "limit_order",
        "inputs_abi": "(uint32 asset, bool isBuy, uint64 limitPx, uint64 sz, bool reduceOnly, uint8 encodedTif, uint128 cloid)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_core_limit_order",
            "hl_core_limit_order": {
              "asset": "$inputs.asset",
              "is_buy": "$inputs.isBuy",
              "limit_px": "$inputs.limitPx",
              "sz": "$inputs.sz",
              "reduce_only": "$inputs.reduceOnly",
              "encoded_tif": "$inputs.encodedTif",
              "cloid": "$inputs.cloid"
            }
          }
        },
        "_note": "Structured as a HyperliquidCore raw limit-order action, not Perp(PlaceOrder): asset is an HL asset id, limitPx/sz are raw fixed-point uint64 values, and encodedTif is a raw byte. The decoder exposes side/reduceOnly for policy while preserving exact raw fields."
      },
      "2": {
        "name": "vault_transfer",
        "inputs_abi": "(address vault, bool isDeposit, uint64 usd)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "vaultTransfer" }
          }
        }
      },
      "3": {
        "name": "token_delegate",
        "inputs_abi": "(address validator, uint64 wei, bool isUndelegate)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "tokenDelegate" }
          }
        }
      },
      "4": {
        "name": "staking_deposit",
        "inputs_abi": "(uint64 wei)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "stakingDeposit" }
          }
        }
      },
      "5": {
        "name": "staking_withdraw",
        "inputs_abi": "(uint64 wei)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "stakingWithdraw" }
          }
        }
      },
      "6": {
        "name": "spot_send",
        "inputs_abi": "(address destination, uint64 token, uint64 wei)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "spotSend" }
          }
        },
        "_note": "token/wei are uint64 L1 identifiers (not EVM address/U256), so token.erc20_transfer would mislabel. Kept Unknown."
      },
      "7": {
        "name": "usd_class_transfer",
        "inputs_abi": "(uint64 ntl, bool toPerp)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "usdClassTransfer" }
          }
        }
      },
      "8": {
        "name": "finalize_evm_contract",
        "inputs_abi": "(uint64 token, uint8 encodedFinalizeEvmContractVariant, uint64 createNonce)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "finalizeEvmContract" }
          }
        }
      },
      "9": {
        "name": "add_api_wallet",
        "inputs_abi": "(address apiWalletAddress, string apiWalletName)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "addApiWallet" }
          }
        }
      },
      "10": {
        "name": "cancel_order_by_oid",
        "inputs_abi": "(uint32 asset, uint64 oid)",
        "body": {
          "domain": "perp",
          "perp": {
            "action": "cancel_order",
            "cancel_order": {
              "venue": { "name": "hyperliquid", "chain": "$chain" },
              "order_id": {
                "$fn": "uint_to_string",
                "$args": ["$inputs.oid"]
              }
            }
          }
        },
        "_note": "Structured Perp(CancelOrder): oid is uint64, so the manifest normalizes it to a decimal string with uint_to_string before filling order_id:String."
      },
      "11": {
        "name": "cancel_order_by_cloid",
        "inputs_abi": "(uint32 asset, uint128 cloid)",
        "body": {
          "domain": "perp",
          "perp": {
            "action": "cancel_order",
            "cancel_order": {
              "venue": { "name": "hyperliquid", "chain": "$chain" },
              "order_id": "$inputs.cloid"
            }
          }
        },
        "_note": "Structured Perp(CancelOrder): cloid is uint128 (renders as JSON string), accepted by order_id:String. PerpVenue::Hyperliquid{chain} exists, CancelOrderAction has no live_inputs. The one CoreWriter action that maps cleanly to a perp domain body."
      },
      "12": {
        "name": "approve_builder_fee",
        "inputs_abi": "(uint64 maxFeeRate, address builder)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "approveBuilderFee" }
          }
        }
      },
      "13": {
        "name": "send_asset",
        "inputs_abi": "(address destination, address subAccount, uint32 source_dex, uint32 destination_dex, uint64 token, uint64 wei)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "sendAsset" }
          }
        }
      },
      "14": {
        "name": "reflect_evm_supply_change",
        "inputs_abi": "(uint64 token, uint64 wei, bool is_mint)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "reflectEvmSupplyChange" }
          }
        }
      },
      "15": {
        "name": "borrow_lend_operation",
        "inputs_abi": "(uint8 encodedOperation, uint64 token, uint64 wei)",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "borrowLendOperation" }
          }
        },
        "_note": "HL native borrow/lend, but token/wei are uint64 L1 identifiers and encodedOperation (0=Supply,1=Withdraw) is a uint8 not a lending action tag — does not fit the lending domain (TokenRef address + U256 amount). Unknown."
      },
      "default": {
        "name": "unrecognized_action",
        "body": {
          "domain": "hyperliquid_core",
          "hyperliquid_core": {
            "action": "hl_unknown",
            "hl_unknown": { "action_type": "unrecognizedCoreWriterAction" }
          }
        },
        "_note": "Fail-soft fallback for version mismatch / unknown action_id / future action 16+. Raw call preserved via $calldata."
      }
    }
  },
  "requires": {
    "imperative": ["core-writer-dispatcher@^1.0"],
    "adapter_capabilities": [],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
