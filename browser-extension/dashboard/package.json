{
  "name": "dambi-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Policy management UI for the dambi browser extension. Standalone Vite app, communicates with the extension SW through the SDK at ../sdk/extension-client.ts.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:catalog": "node scripts/gen-field-catalog.mjs",
    "gen:registry": "node scripts/gen-enrichment-registry.mjs",
    "check:i18n": "node scripts/check-i18n-hardcoded.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tanstack/react-query": "^5.59.0",
    "blockly": "13.0.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.4.1",
    "i18next": "^26.3.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "6.30.4",
    "wanted-sans": "^1.0.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10",
    "@testing-library/react": "^16",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "27.4.0",
    "terser": "5.48.0",
    "typescript": "^5.4.0",
    "vite": "7.3.5",
    "vitest": "4.1.9"
  }
}
