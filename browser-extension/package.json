{
  "name": "dambi-extension",
  "version": "0.1.2",
  "private": true,
  "description": "Policy-engine-backed wallet transaction safety extension",
  "workspaces": [
    "dashboard"
  ],
  "scripts": {
    "dev:chrome": "yarn prepare:defaults && yarn prepare:wasm && cross-env TARGET_BROWSER=chrome webpack --config webpack/webpack.dev.js --watch",
    "dev:firefox": "yarn prepare:defaults && yarn prepare:wasm && cross-env TARGET_BROWSER=firefox webpack --config webpack/webpack.dev.js --watch",
    "build:chrome:webpack": "yarn prepare:defaults && yarn prepare:wasm && cross-env TARGET_BROWSER=chrome webpack --config webpack/webpack.prod.js",
    "build:firefox:webpack": "yarn prepare:defaults && yarn prepare:wasm && cross-env TARGET_BROWSER=firefox webpack --config webpack/webpack.prod.js",
    "build:options": "yarn workspace dambi-dashboard build",
    "validate:dist": "node scripts/validate-dist.js",
    "build:chrome": "cross-env TARGET_BROWSER=chrome run-s build:chrome:webpack build:options validate:dist",
    "build:firefox": "cross-env TARGET_BROWSER=firefox run-s build:firefox:webpack build:options validate:dist",
    "build:ext": "yarn build:chrome",
    "prepare:defaults": "node scripts/copy-default-policies.js && node scripts/copy-default-manifests.js && node scripts/copy-method-catalog.js",
    "prepare:wasm": "../scripts/wasm-build.sh",
    "build": "run-s build:chrome build:firefox",
    "zip:chrome": "cross-env NO_UPDATE_NOTIFIER=1 web-ext build -s dist/chrome -a dist -n chrome.zip -o",
    "zip:chrome:webstore": "node scripts/build-webstore-zip.js",
    "zip:firefox": "cross-env NO_UPDATE_NOTIFIER=1 web-ext build -s dist/firefox -a dist -n firefox.zip -o",
    "zip": "run-s zip:chrome zip:chrome:webstore zip:firefox",
    "clean": "rimraf dist",
    "typecheck": "yarn prepare:wasm && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --write ."
  },
  "dependencies": {
    "@metamask/post-message-stream": "10.0.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "canonicalize": "^3.0.0",
    "eth-rpc-errors": "^4.0.3",
    "jszip": "^3.10.1",
    "object-hash": "^3.0.0",
    "process": "^0.11.10",
    "viem": "2.52.2",
    "webextension-polyfill": "^0.12.0"
  },
  "resolutions": {
    "ajv@npm:^6.12.4": "npm:6.14.0",
    "ajv@npm:^8.9.0": "npm:8.20.0",
    "brace-expansion@npm:^1.1.7": "npm:1.1.15",
    "brace-expansion@npm:^2.0.1": "npm:2.1.1",
    "braces@npm:^3.0.3": "npm:3.0.3",
    "cross-spawn@npm:^7.0.6": "npm:7.0.6",
    "encoding-sniffer@npm:^0.2.1": "npm:1.0.2",
    "json5@npm:^2.1.2": "npm:2.2.3",
    "micromatch@npm:^4.0.0": "npm:4.0.8",
    "minimatch@npm:^3.0.4": "npm:3.1.5",
    "minimatch@npm:^3.1.1": "npm:3.1.5",
    "minimatch@npm:^5.0.1": "npm:5.1.9",
    "node-forge@npm:^1.3.1": "npm:1.4.0",
    "node-gyp@npm:latest": "npm:12.4.0",
    "picomatch@npm:^2.3.1": "npm:2.3.2",
    "semver@npm:^7.3.4": "npm:7.8.4",
    "semver@npm:^7.3.5": "npm:7.8.4",
    "socks@npm:^2.6.2": "npm:2.8.9",
    "tar@npm:^7.5.4": "npm:7.5.16",
    "uuid@npm:^9.0.1": "npm:11.1.1",
    "vite@npm:^6.0.0 || ^7.0.0 || ^8.0.0": "npm:7.3.5",
    "ws@npm:8.20.1": "npm:8.21.0",
    "ws@npm:^8.18.3": "npm:8.21.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/object-hash": "^3.0.6",
    "@types/webextension-polyfill": "^0.10.7",
    "@vitest/ui": "4.1.9",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "14.0.0",
    "cross-env": "10.1.0",
    "css-loader": "^7.1.4",
    "dotenv-webpack": "^8.1.0",
    "happy-dom": "^20.9.0",
    "npm-run-all2": "9.0.2",
    "prettier": "^3.3.1",
    "rimraf": "6.1.3",
    "style-loader": "^4.0.0",
    "ts-loader": "9.6.1",
    "typescript": "^5.7.3",
    "vitest": "4.1.9",
    "web-ext": "10.4.0",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3",
    "webpack-merge": "^5.10.0",
    "wext-manifest-loader": "3.0.2",
    "wext-manifest-webpack-plugin": "^1.4.1"
  },
  "packageManager": "yarn@4.14.1"
}
